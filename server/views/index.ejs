<div class="app-container">
  <%- include('partials/sidebar', { page: 'dashboard', user: user }) %>
  <div class="main-content">
    <%- include('partials/navbar', { title: 'Tableau de bord', user: user }) %>
    <div class="content-wrapper">

      <!-- Stats Cards -->
      <div class="stats-grid">
        <div class="stat-card stat-card-blue">
          <div class="stat-icon"><i class="fas fa-file-invoice-dollar"></i></div>
          <div class="stat-info">
            <span class="stat-label">Total Factures</span>
            <span class="stat-value" id="totalInvoices">—</span>
          </div>
        </div>
        <div class="stat-card stat-card-red">
          <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
          <div class="stat-info">
            <span class="stat-label">En Retard</span>
            <span class="stat-value" id="overdueInvoices">—</span>
          </div>
        </div>
        <div class="stat-card stat-card-green">
          <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
          <div class="stat-info">
            <span class="stat-label">Montant Encaissé</span>
            <span class="stat-value" id="totalPaid">—</span>
          </div>
        </div>
        <div class="stat-card stat-card-orange">
          <div class="stat-icon"><i class="fas fa-clock"></i></div>
          <div class="stat-info">
            <span class="stat-label">Montant Dû</span>
            <span class="stat-value" id="totalDue">—</span>
          </div>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="charts-grid">
        <div class="card">
          <div class="card-header">
            <h3><i class="fas fa-chart-donut"></i> Répartition des factures</h3>
          </div>
          <div class="card-body">
            <canvas id="invoiceChart" height="240"></canvas>
          </div>
        </div>
        <div class="card">
          <div class="card-header">
            <h3><i class="fas fa-tasks"></i> Actions de recouvrement</h3>
          </div>
          <div class="card-body">
            <canvas id="recoveryChart" height="240"></canvas>
          </div>
        </div>
      </div>

      <!-- Recent Overdue -->
      <div class="card mt-4">
        <div class="card-header">
          <h3><i class="fas fa-exclamation-circle text-danger"></i> Factures en retard</h3>
          <a href="/invoices?status=overdue" class="btn btn-sm btn-outline">Voir tout</a>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table">
              <thead>
                <tr>
                  <th>N° Facture</th>
                  <th>Client</th>
                  <th>Montant</th>
                  <th>Échéance</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="overdueTable">
                <tr><td colspan="5" class="text-center"><div class="loading-spinner"></div></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const token = localStorage.getItem('token');
if (!token) window.location.href = '/login';

async function loadDashboard() {
  try {
    const [statsRes, actStatsRes, overdueRes] = await Promise.all([
      fetch('/api/invoice/stats', { headers: { Authorization: 'Bearer ' + token } }),
      fetch('/api/recovery/stats', { headers: { Authorization: 'Bearer ' + token } }),
      fetch('/api/invoice/overdue', { headers: { Authorization: 'Bearer ' + token } }),
    ]);
    const stats = await statsRes.json();
    const actStats = await actStatsRes.json();
    const overdue = await overdueRes.json();

    document.getElementById('totalInvoices').textContent = stats.total || 0;
    document.getElementById('overdueInvoices').textContent = stats.overdue || 0;
    document.getElementById('totalPaid').textContent = formatCurrency(stats.totalPaid || 0);
    document.getElementById('totalDue').textContent = formatCurrency(stats.totalDue || 0);

    new Chart(document.getElementById('invoiceChart'), {
      type: 'doughnut',
      data: {
        labels: ['Payées', 'Impayées', 'En retard', 'En cours'],
        datasets: [{ data: [stats.paid, stats.unpaid, stats.overdue, stats.pending],
          backgroundColor: ['#10b981','#3b82f6','#ef4444','#f59e0b'], borderWidth: 0 }]
      },
      options: { plugins: { legend: { position: 'bottom' } }, cutout: '65%' }
    });

    const ao = actStats.byOutcome || {};
    new Chart(document.getElementById('recoveryChart'), {
      type: 'bar',
      data: {
        labels: ['En attente', 'Réussi', 'Échoué', 'Reporté'],
        datasets: [{ label: 'Actions', data: [ao.pending, ao.successful, ao.failed, ao.rescheduled],
          backgroundColor: ['#3b82f6','#10b981','#ef4444','#f59e0b'], borderRadius: 6 }]
      },
      options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
    });

    const tbody = document.getElementById('overdueTable');
    const list = overdue.data || overdue;
    tbody.innerHTML = list.length === 0 ? '<tr><td colspan="5" class="text-center text-muted">Aucune facture en retard 🎉</td></tr>'
      : list.slice(0, 5).map(inv => `
        <tr>
          <td><span class="badge badge-blue">${inv.number}</span></td>
          <td>${inv.client?.company || inv.client?.name || '—'}</td>
          <td class="text-danger fw-bold">${formatCurrency(inv.amount)}</td>
          <td>${new Date(inv.dueDate).toLocaleDateString('fr-FR')}</td>
          <td><a href="/invoices/${inv._id}" class="btn btn-sm btn-outline"><i class="fas fa-eye"></i></a></td>
        </tr>`).join('');
  } catch (e) {
    console.error(e);
  }
}

function formatCurrency(n) {
  return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR' }).format(n);
}
loadDashboard();
</script>
