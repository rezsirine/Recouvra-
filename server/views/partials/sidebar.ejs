<aside class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <div class="brand-logo">
      <i class="fas fa-shield-alt"></i>
    </div>
    <div class="brand-text">
      <span class="brand-name">Recouvra+</span>
      <span class="brand-sub">Gestion de recouvrement</span>
    </div>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section">
      <span class="nav-label">Principal</span>
      <a href="/dashboard" class="nav-item <%= typeof page !== 'undefined' && page === 'dashboard' ? 'active' : '' %>">
        <i class="fas fa-chart-pie"></i>
        <span>Tableau de bord</span>
      </a>
    </div>
    <div class="nav-section">
      <span class="nav-label">Gestion</span>
      <a href="/clients" class="nav-item <%= typeof page !== 'undefined' && page === 'clients' ? 'active' : '' %>">
        <i class="fas fa-users"></i>
        <span>Clients</span>
      </a>
      <a href="/invoices" class="nav-item <%= typeof page !== 'undefined' && page === 'invoices' ? 'active' : '' %>">
        <i class="fas fa-file-invoice-dollar"></i>
        <span>Factures</span>
        <% if (typeof overdueCount !== 'undefined' && overdueCount > 0) { %>
          <span class="badge badge-danger"><%= overdueCount %></span>
        <% } %>
      </a>
      <a href="/recovery" class="nav-item <%= typeof page !== 'undefined' && page === 'recovery' ? 'active' : '' %>">
        <i class="fas fa-tasks"></i>
        <span>Recouvrement</span>
      </a>
    </div>
    <% if (typeof user !== 'undefined' && (user.role === 'admin' || user.role === 'manager')) { %>
    <div class="nav-section">
      <span class="nav-label">Administration</span>
      <a href="/users" class="nav-item <%= typeof page !== 'undefined' && page === 'users' ? 'active' : '' %>">
        <i class="fas fa-user-cog"></i>
        <span>Utilisateurs</span>
      </a>
    </div>
    <% } %>
  </nav>

  <div class="sidebar-footer">
    <div class="user-info">
      <div class="user-avatar" id="userAvatar">U</div>
      <div class="user-details">
        <span class="user-name" id="userName">Chargement...</span>
        <span class="user-role" id="userRole">---</span>
      </div>
    </div>
    <a href="/logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i></a>
  </div>
</aside>

<script>
// Script ultra-simple - ATTENDEZ que la page soit chargée
window.addEventListener('load', function() {
  console.log('✅ Sidebar: window.load');
  
  // Récupérer le token
  const token = localStorage.getItem('token');
  console.log('🔑 Token:', token ? token.substring(0, 15) + '...' : 'Pas de token');
  
  if (!token) {
    console.log('❌ Pas de token');
    document.getElementById('userName').textContent = 'Non connecté';
    return;
  }
  
  // Appeler l'API
  fetch('/api/user/me', {
    headers: {
      'Authorization': 'Bearer ' + token
    }
  })
  .then(response => {
    console.log('📥 Status réponse:', response.status);
    if (!response.ok) {
      throw new Error('Erreur ' + response.status);
    }
    return response.json();
  })
  .then(user => {
    console.log('✅ Utilisateur reçu:', user);
    
    // Mettre à jour les éléments
    document.getElementById('userName').textContent = user.name || 'Utilisateur';
    document.getElementById('userRole').textContent = user.role || 'agent';
    document.getElementById('userAvatar').textContent = user.name ? user.name.charAt(0).toUpperCase() : 'U';
    
    // Ajouter la classe de rôle
    document.getElementById('userRole').className = 'user-role badge-role-' + (user.role || 'agent');
  })
  .catch(error => {
    console.error('❌ Erreur:', error);
    document.getElementById('userName').textContent = 'Erreur';
    document.getElementById('userRole').textContent = '---';
  });
});
</script>