<!-- Stats Cards -->
<div class="stats-grid">
  <div class="stat-card stat-card-blue">
    <div class="stat-icon"><i class="fas fa-file-invoice-dollar"></i></div>
    <div class="stat-info">
      <span class="stat-label">Total Factures</span>
      <span class="stat-value" id="statTotal">0</span>
    </div>
  </div>
  <div class="stat-card stat-card-green">
    <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
    <div class="stat-info">
      <span class="stat-label">Payées</span>
      <span class="stat-value" id="statPaid">0</span>
    </div>
  </div>
  <div class="stat-card stat-card-red">
    <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
    <div class="stat-info">
      <span class="stat-label">En Retard</span>
      <span class="stat-value" id="statOverdue">0</span>
    </div>
  </div>
  <div class="stat-card stat-card-orange">
    <div class="stat-icon"><i class="fas fa-clock"></i></div>
    <div class="stat-info">
      <span class="stat-label">En cours</span>
      <span class="stat-value" id="statPending">0</span>
    </div>
  </div>
</div>

<!-- Montants -->
<div class="stats-grid" style="margin-top:16px">
  <div class="stat-card stat-card-blue">
    <div class="stat-icon"><i class="fas fa-coins"></i></div>
    <div class="stat-info">
      <span class="stat-label">Montant Total</span>
      <span class="stat-value" id="totalAmount">0 €</span>
    </div>
  </div>
  <div class="stat-card stat-card-green">
    <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
    <div class="stat-info">
      <span class="stat-label">Montant Encaissé</span>
      <span class="stat-value" id="totalPaid">0 €</span>
    </div>
  </div>
  <div class="stat-card stat-card-orange">
    <div class="stat-icon"><i class="fas fa-clock"></i></div>
    <div class="stat-info">
      <span class="stat-label">Montant Dû</span>
      <span class="stat-value" id="totalDue">0 €</span>
    </div>
  </div>
</div>

<!-- Charts Row -->
<div class="charts-grid">
  <div class="card">
    <div class="card-header">
      <h3><i class="fas fa-chart-pie"></i> Répartition des factures</h3>
    </div>
    <div class="card-body">
      <canvas id="invoiceChart" height="200"></canvas>
    </div>
  </div>
  <div class="card">
    <div class="card-header">
      <h3><i class="fas fa-tasks"></i> Actions de recouvrement à venir</h3>
    </div>
    <div class="card-body">
      <div id="recentActions"></div>
    </div>
  </div>
</div>

<!-- Factures en retard -->
<div class="card mt-4">
  <div class="card-header">
    <h3><i class="fas fa-exclamation-circle text-danger"></i> Factures en retard</h3>
    <a href="/invoices" class="btn btn-sm btn-outline">Voir tout</a>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr><th>N° Facture</th><th>Client</th><th>Montant</th><th>Échéance</th><th>Actions</th></tr>
        </thead>
        <tbody id="overdueList">
          <tr><td colspan="5" class="text-center">Chargement...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
(function() {
  function drawCharts() {
    const token = localStorage.getItem('token');
    fetch('/api/invoice/stats', {
      headers: { 'Authorization': 'Bearer ' + token }
    })
    .then(r => r.json())
    .then(stats => {
      const ctx1 = document.getElementById('invoiceChart')?.getContext('2d');
      if (ctx1 && stats) {
        new Chart(ctx1, {
          type: 'doughnut',
          data: {
            labels: ['Payées', 'Impayées', 'En retard', 'En cours'],
            datasets: [{
              data: [stats.paid||0, stats.unpaid||0, stats.overdue||0, stats.pending||0],
              backgroundColor: ['#10b981','#3b82f6','#ef4444','#f59e0b'],
              borderWidth: 0
            }]
          },
          options: { plugins: { legend: { position: 'bottom' } }, cutout: '65%' }
        });
      }
    });
  }

  setTimeout(drawCharts, 500);
})();
</script>