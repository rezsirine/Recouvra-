<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mot de passe oublié — Recouvra+</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body class="auth-body">
  <div class="auth-simple">
    <div class="auth-card auth-card-center">

      <!-- Formulaire -->
      <div id="forgotForm">
        <div class="auth-icon-header">
          <div class="icon-circle"><i class="fas fa-key"></i></div>
          <h2>Mot de passe oublié ?</h2>
          <p>Entrez votre email pour recevoir un lien de réinitialisation.</p>
        </div>

        <div id="alertMsg" class="alert alert-danger" style="display:none"></div>

        <form class="auth-form" onsubmit="handleForgot(event)">
          <div class="form-group">
            <label class="form-label"><i class="fas fa-envelope"></i> Email</label>
            <input type="email" id="email" class="form-control" placeholder="votre@email.com" required />
          </div>
          <button type="submit" class="btn btn-primary btn-full btn-lg" id="submitBtn">
            <span class="btn-text"><i class="fas fa-paper-plane"></i> Envoyer le lien</span>
            <span class="btn-loader"><div class="loading-spinner"></div></span>
          </button>
        </form>

        <div class="text-center mt-3">
          <a href="/login" class="link-primary"><i class="fas fa-arrow-left"></i> Retour à la connexion</a>
        </div>
      </div>

      <!-- Message de succès -->
      <div id="successMsg" style="display:none">
        <div class="success-message">
          <div class="success-icon"><i class="fas fa-check"></i></div>
          <h3 style="color:var(--primary); margin-bottom:8px;">Email envoyé !</h3>
          <p style="color:var(--gray-500);">Vérifiez votre boîte mail et cliquez sur le lien pour réinitialiser votre mot de passe.</p>
          <a href="/login" class="btn btn-outline mt-3">
            <i class="fas fa-arrow-left"></i> Retour à la connexion
          </a>
        </div>
      </div>

    </div>
  </div>
  <script src="/js/main.js"></script>
</body>
</html>
