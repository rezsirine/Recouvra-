<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mot de passe oublié — Recouvra+</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="auth-body">
  <div class="auth-simple">
    <div class="auth-card auth-card-center">
      <div class="auth-icon-header">
        <div class="icon-circle"><i class="fas fa-key"></i></div>
        <h2>Mot de passe oublié ?</h2>
        <p>Entrez votre email pour recevoir un lien de réinitialisation.</p>
      </div>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
      <% } %>
      <form action="/forgot-password" method="POST" class="auth-form">
        <div class="form-group">
          <label class="form-label"><i class="fas fa-envelope"></i> Email</label>
          <input type="email" name="email" class="form-control" placeholder="votre@email.com" required />
        </div>
        <button type="submit" class="btn btn-primary btn-full btn-lg">
          <i class="fas fa-paper-plane"></i> Envoyer le lien
        </button>
      </form>
      <div class="text-center mt-3">
        <a href="/login" class="link-primary"><i class="fas fa-arrow-left"></i> Retour à la connexion</a>
      </div>
    </div>
  </div>
  <script src="/js/main.js"></script>
</body>
</html>
