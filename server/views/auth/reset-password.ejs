<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nouveau mot de passe — Recouvra+</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="auth-body">
  <div class="auth-simple">
    <div class="auth-card auth-card-center">
      <div class="auth-icon-header">
        <div class="icon-circle"><i class="fas fa-lock-open"></i></div>
        <h2>Nouveau mot de passe</h2>
        <p>Choisissez un nouveau mot de passe sécurisé.</p>
      </div>
      <div id="alertBox"></div>
      <form id="resetForm" class="auth-form">
        <input type="hidden" id="tokenField" value="<%= token %>" />
        <div class="form-group">
          <label class="form-label"><i class="fas fa-lock"></i> Nouveau mot de passe</label>
          <div class="input-icon-right">
            <input type="password" id="passwordField" class="form-control" placeholder="••••••••" required minlength="6" />
            <button type="button" class="toggle-password" onclick="togglePassword()"><i class="fas fa-eye" id="eyeIcon"></i></button>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label"><i class="fas fa-lock"></i> Confirmer le mot de passe</label>
          <input type="password" id="confirmPassword" class="form-control" placeholder="••••••••" required />
        </div>
        <button type="submit" class="btn btn-primary btn-full btn-lg"><i class="fas fa-save"></i> Enregistrer</button>
      </form>
      <div class="text-center mt-3"><a href="/login" class="link-primary"><i class="fas fa-arrow-left"></i> Retour</a></div>
    </div>
  </div>
  <script src="/js/main.js"></script>
  <script>
    document.getElementById('resetForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const token = document.getElementById('tokenField').value;
      const password = document.getElementById('passwordField').value;
      const confirm = document.getElementById('confirmPassword').value;
      const alertBox = document.getElementById('alertBox');
      if (password !== confirm) {
        alertBox.innerHTML = '<div class="alert alert-danger">Les mots de passe ne correspondent pas</div>';
        return;
      }
      const res = await fetch('/api/user/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, password }),
      });
      const data = await res.json();
      if (res.ok) {
        alertBox.innerHTML = '<div class="alert alert-success">Mot de passe réinitialisé ! Redirection...</div>';
        setTimeout(() => window.location.href = '/login', 2000);
      } else {
        alertBox.innerHTML = `<div class="alert alert-danger">${data.message}</div>`;
      }
    });
  </script>
</body>
</html>
