<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nouveau mot de passe — Recouvra+</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body class="auth-body">
  <div class="auth-simple">
    <div class="auth-card auth-card-center">
      <div class="auth-icon-header">
        <div class="icon-circle"><i class="fas fa-lock-open"></i></div>
        <h2>Nouveau mot de passe</h2>
        <p>Choisissez un nouveau mot de passe sécurisé.</p>
      </div>

      <div id="alertMsg" class="alert" style="display:none"></div>

      <form class="auth-form" onsubmit="handleReset(event)">
        <!-- Token caché récupéré depuis l'URL -->
        <input type="hidden" id="resetToken" value="<%= token %>" />

        <div class="form-group">
          <label class="form-label"><i class="fas fa-lock"></i> Nouveau mot de passe</label>
          <div class="input-icon-right">
            <input type="password" id="password" class="form-control" placeholder="••••••••" required minlength="6" />
            <button type="button" class="toggle-password" onclick="togglePasswordReset()">
              <i class="fas fa-eye" id="eyeIconReset"></i>
            </button>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label"><i class="fas fa-lock"></i> Confirmer le mot de passe</label>
          <input type="password" id="confirmPassword" class="form-control" placeholder="••••••••" required />
        </div>

        <button type="submit" class="btn btn-primary btn-full btn-lg" id="submitBtn">
          <span class="btn-text"><i class="fas fa-save"></i> Enregistrer</span>
          <span class="btn-loader"><div class="loading-spinner"></div></span>
        </button>
      </form>

      <div class="text-center mt-3">
        <a href="/login" class="link-primary"><i class="fas fa-arrow-left"></i> Retour à la connexion</a>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
  <script>
    // Toggle spécifique à cette page (pas de conflit avec login)
    const togglePasswordReset = () => {
      const input = document.getElementById('password');
      const icon  = document.getElementById('eyeIconReset');
      if (input.type === 'password') { input.type = 'text';     icon.className = 'fas fa-eye-slash'; }
      else                           { input.type = 'password'; icon.className = 'fas fa-eye'; }
    };
  </script>
</body>
</html>
