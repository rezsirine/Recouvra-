<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Inscription — Recouvra+</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body class="auth-body">

  <div class="auth-container">
    <!-- Colonne gauche : présentation -->
    <div class="auth-left">
      <div class="auth-left-content">
        <div class="auth-brand">
          <div class="auth-brand-icon"><i class="fas fa-shield-alt"></i></div>
          <h1>Recouvra+</h1>
        </div>
        <h2>Rejoignez la plateforme de recouvrement</h2>
        <p>Créez votre compte et commencez à gérer vos factures, clients et actions de recouvrement efficacement.</p>
        <div class="auth-features">
          <div class="feature-item"><i class="fas fa-check-circle"></i><span>Suivi des factures impayées</span></div>
          <div class="feature-item"><i class="fas fa-check-circle"></i><span>Gestion des actions de recouvrement</span></div>
          <div class="feature-item"><i class="fas fa-check-circle"></i><span>Statistiques en temps réel</span></div>
          <div class="feature-item"><i class="fas fa-check-circle"></i><span>Notifications automatiques</span></div>
        </div>
      </div>
    </div>

    <!-- Colonne droite : formulaire d'inscription -->
    <div class="auth-right">
      <div class="auth-card">
        <div class="auth-card-header">
          <h2>Créer un compte</h2>
          <p>Rejoignez Recouvra+ dès maintenant</p>
        </div>

        <!-- Alerte erreur/succès -->
        <div id="alertMsg" class="alert alert-danger" style="display:none"></div>

        <form id="signupForm" class="auth-form" onsubmit="handleSignup(event)">
          <!-- Nom complet -->
          <div class="form-group">
            <label class="form-label"><i class="fas fa-user"></i> Nom complet *</label>
            <input type="text" id="name" class="form-control" placeholder="Jean Dupont" required />
          </div>

          <!-- Email -->
          <div class="form-group">
            <label class="form-label"><i class="fas fa-envelope"></i> Email *</label>
            <input type="email" id="email" class="form-control" placeholder="votre@email.com" required />
          </div>

          <!-- Téléphone -->
          <div class="form-group">
            <label class="form-label"><i class="fas fa-phone"></i> Téléphone</label>
            <input type="tel" id="phone" class="form-control" placeholder="+33 6 00 00 00 00" />
          </div>

          <!-- Rôle -->
          <div class="form-group">
            <label class="form-label"><i class="fas fa-shield-alt"></i> Rôle *</label>
            <select id="role" class="form-control" required>
              <option value="agent">Agent</option>
              <option value="manager">Manager</option>
              <option value="admin">Admin</option>
            </select>
          </div>

          <!-- Mot de passe -->
          <div class="form-group">
            <label class="form-label"><i class="fas fa-lock"></i> Mot de passe *</label>
            <div class="input-icon-right">
              <input type="password" id="password" class="form-control" placeholder="••••••••" required minlength="6" />
              <button type="button" class="toggle-password" onclick="togglePassword()">
                <i class="fas fa-eye" id="eyeIcon"></i>
              </button>
            </div>
          </div>

          <!-- Conditions -->
          <div class="form-footer">
            <label class="checkbox-label">
              <input type="checkbox" required /> 
              <span>J'accepte les <a href="#" class="link-primary">conditions d'utilisation</a></span>
            </label>
          </div>

          <button type="submit" class="btn btn-primary btn-full btn-lg" id="signupBtn">
            <span class="btn-text"><i class="fas fa-user-plus"></i> Créer mon compte</span>
            <span class="btn-loader"><div class="loading-spinner"></div></span>
          </button>
        </form>

        <div class="auth-divider"><span>Déjà inscrit ?</span></div>
        <a href="/login" class="btn btn-outline btn-full">
          <i class="fas fa-sign-in-alt"></i> Se connecter
        </a>
      </div>
    </div>
  </div>

  <script>
    // Fonction pour basculer l'affichage du mot de passe
    function togglePassword() {
      const passwordInput = document.getElementById('password');
      const eyeIcon = document.getElementById('eyeIcon');
      
      if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        eyeIcon.className = 'fas fa-eye-slash';
      } else {
        passwordInput.type = 'password';
        eyeIcon.className = 'fas fa-eye';
      }
    }

    // UNE SEULE FONCTION handleSignup - celle qui redirige vers LOGIN
    async function handleSignup(e) {
      e.preventDefault();
      
      const btn = document.getElementById('signupBtn');
      const alertMsg = document.getElementById('alertMsg');
      
      // Désactiver le bouton et afficher le loader
      btn.disabled = true;
      btn.querySelector('.btn-text').style.display = 'none';
      btn.querySelector('.btn-loader').style.display = 'block';
      
      try {
        const name = document.getElementById('name').value;
        const email = document.getElementById('email').value;
        const phone = document.getElementById('phone').value;
        const password = document.getElementById('password').value;
        const role = document.getElementById('role').value;
        
        // Validation basique
        if (!name || !email || !password || !role) {
          throw new Error('Veuillez remplir tous les champs obligatoires');
        }
        
        if (password.length < 6) {
          throw new Error('Le mot de passe doit contenir au moins 6 caractères');
        }
        
        console.log('📤 Envoi des données...', { name, email, phone, role });
        
        const res = await fetch('/api/user/signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name,
            email,
            phone_number: phone || undefined,
            password,
            role
          })
        });
        
        const data = await res.json();
        console.log('📥 Réponse reçue:', data);
        
        if (!res.ok) throw new Error(data.message || 'Erreur lors de l\'inscription');
        
        // ✅ Message de succès
        alertMsg.className = 'alert alert-success';
        alertMsg.innerHTML = `
          <i class="fas fa-check-circle"></i>
          <div>
            <strong>Compte créé avec succès !</strong><br>
            <small>Vous allez être redirigé vers la page de connexion...</small>
          </div>
        `;
        alertMsg.style.display = 'flex';
        
        // ✅ NE PAS STOCKER LE TOKEN
        // localStorage.setItem('token', data.token); ← Commenté !
        
        // ✅ Nettoyer le formulaire
        document.getElementById('signupForm').reset();
        
        // ✅ Rediriger vers LOGIN après 2 secondes
        setTimeout(() => {
          console.log('🚀 Redirection vers /login');
          window.location.href = '/login';
        }, 2000);
        
      } catch (err) {
        console.error('❌ Erreur inscription:', err);
        
        alertMsg.className = 'alert alert-danger';
        alertMsg.innerHTML = `
          <i class="fas fa-exclamation-circle"></i>
          <div>
            <strong>Erreur</strong><br>
            <small>${err.message}</small>
          </div>
        `;
        alertMsg.style.display = 'flex';
        
        // Réactiver le bouton
        btn.disabled = false;
        btn.querySelector('.btn-text').style.display = 'block';
        btn.querySelector('.btn-loader').style.display = 'none';
      }
    }
  </script>
</body>
</html>