{
  "name": "server",
  "version": "1.0.0",
  "description": "greenfield e-commerce project",
  "main": "index.js",
  "scripts": {
    "start": "nodemon index.js",
    "test": "jest --testEnvironment node --forceExit"
  },
  "jest": {
  "testEnvironment": "node",
  "roots": ["<rootDir>/__tests__"],
  "testMatch": ["**/__tests__/**/*.test.js"],
  "testPathIgnorePatterns": ["/node_modules/", "/public/"],
  "globalSetup": "./__tests__/setup.js",
  "globalTeardown": "./__tests__/teardown.js",
  "testTimeout": 15000
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GreenField-Team-B/zara-project.git"
  },
  "author": "Team-B",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.3.1",
    "nodemailer": "^6.9.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}